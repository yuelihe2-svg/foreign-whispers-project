# ─────────────────────────────────────────────────────────────────────────────
# Foreign Whispers — environment variables
#
# Copy this file to `.env` and fill in the values. The real `.env` is
# git-ignored and must NEVER be committed (it contains secrets).
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Host user (Linux / macOS only) ──────────────────────────────────────────
# Used by the API container so files created under ./pipeline_data are owned
# by your host user rather than root. On Windows Docker Desktop, the defaults
# below are fine.
#
#   Linux / macOS:  run `id -u` and `id -g`, paste the numbers below.
UID=1000
GID=1000

# ── Hugging Face token ──────────────────────────────────────────────────────
# Required ONLY if you enable optional speaker diarization via pyannote.audio.
# The core STT → Translation → TTS → Stitch pipeline works without it.
#
# Create a READ token at: https://huggingface.co/settings/tokens
# Accept the license at: https://huggingface.co/pyannote/speaker-diarization-3.1
#
# Both variable names are set because the notebooks read `HF_TOKEN` while the
# FastAPI service reads `FW_HF_TOKEN` (Pydantic settings env_prefix="FW_").
FW_HF_TOKEN=
HF_TOKEN=

# ── Logfire (optional observability) ────────────────────────────────────────
# Leave blank to disable. Get a write token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=

# ── YouTube cookies (optional, recommended on HPC / cloud IPs) ──────────────
# Path to a Netscape-format cookies file used by yt-dlp. Only needed when
# YouTube challenges downloads with "Sign in to confirm you're not a bot"
# (common on datacenter / HPC IP ranges).
#
# Export cookies from a logged-in browser (e.g. "Get cookies.txt LOCALLY"
# extension), save to the path below, then restart the API container.
# Leave blank (default) if you are running locally and YouTube does not
# challenge you.
#
# Docker default:  mount a cookies.txt at project root and leave blank.
# HPC / manual:    set to an absolute path, e.g. /scratch/$USER/cookies.txt
YT_COOKIES_FILE=
